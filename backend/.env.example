# Supply Chain Optimizer — Environment Variables
# Copy to .env and fill in values

# REQUIRED — generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=

# Set to true for local development (enables SQL logging, includes localhost CORS)
DEBUG=true

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./supply_chain.db

# Frontend origins (comma-separated). In production, set to your actual domain.
# When DEBUG=true, localhost:5173 and localhost:3000 are always included.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (required for Docker Compose — generate a strong password)
# python -c 'import secrets; print(secrets.token_hex(16))'
POSTGRES_USER=logistics_user
POSTGRES_PASSWORD=
POSTGRES_DB=logistics_db

# Redis (required for Docker Compose / Celery)
REDIS_URL=redis://localhost:6379

# Mapping
MAPBOX_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# LIVE RISK FEEDS (backend/app/feeds/) — refreshed every 15 min
# ═══════════════════════════════════════════════════════════════════════════
# A feed with no credential is reported as status="inactive" on /feeds/status
# and in the Dashboard "Live Feeds" panel. It is NEVER silently replaced with a
# fabricated value. Set the keys below to activate the gated feeds.
#
#   GPR Index      — keyless, always live.
#   IMF PortWatch  — keyless, always live.
#   FRED Freight   — keyless by default (public fredgraph CSV endpoint).
#                    FRED_API_KEY is OPTIONAL: it switches the feed to the
#                    authenticated JSON API (higher rate limits, same series).
#   ACLED Conflict — REQUIRES a key. Dormant until both vars below are set.

# ── ACLED (conflict events) — REQUIRED to activate the 4th feed ─────────────
# Free registration; an access key is issued to your email immediately:
#   1. Register:  https://acleddata.com/register/
#   2. Get key:   https://acleddata.com/api-documentation/getting-started
# Both values must be set — the email is sent alongside the key on every call.
ACLED_EMAIL=
ACLED_KEY=

# ── FRED (freight index) — OPTIONAL (feed is live without it) ───────────────
# Free API key (instant, requires a stlouisfed.org account):
#   https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# LEAD-TIME PANEL COLLECTOR (backend/app/ml/lead_time_collector.py)
# ═══════════════════════════════════════════════════════════════════════════
# Polls distributor catalogs weekly for REAL quoted lead times and appends them
# to seeds/data/lead_time_panel/observed_lead_times.csv (the observed-target
# panel the lead-time model is meant to learn from). With NO keys the collector
# logs "no credentials configured" and writes nothing — it never fabricates.
# At least ONE of the two sources below is needed for it to collect anything.
#
# DigiKey API v4 (free, ~1k calls/day) — register: https://developer.digikey.com/
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_SANDBOX=false
#
# Mouser Search API (free, ~1k calls/day, key emailed instantly)
# Register: https://www.mouser.com/api-hub/
MOUSER_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# Other optional API keys (features degrade gracefully without them)
# ═══════════════════════════════════════════════════════════════════════════
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=
OEMSECRETS_API_KEY=
TRUSTEDPARTS_API_KEY=
EASYPOST_API_KEY=
SUPPLYMAVEN_API_KEY=
