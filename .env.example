# Database
DATABASE_URL=postgresql://logistics_user:logistics_password@db:5432/logistics_db

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
DEBUG=true
PROJECT_NAME=Supply Chain Intelligence Platform
API_V1_STR=/api/v1

# NOTE: backend/.env.example is the authoritative, fully-annotated list
# (the app loads backend/.env). This file mirrors the Docker Compose setup.

# ── Live risk feeds ─────────────────────────────────────────────────────────
# ACLED is the only feed that needs a credential; without it the feed reports
# status="inactive" and contributes nothing (no fabricated fallback).
# Free registration: https://acleddata.com/register/
ACLED_EMAIL=
ACLED_KEY=

# OPTIONAL — the FRED freight feed works keyless via the public fredgraph CSV
# endpoint. A key only upgrades it to the authenticated API.
# Free key: https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=

# ── Lead-time panel collector (weekly) ──────────────────────────────────────
# At least one of these is needed for the collector to record real lead times.
# DigiKey: https://developer.digikey.com/   Mouser: https://www.mouser.com/api-hub/
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=

# ── Other external APIs ─────────────────────────────────────────────────────
EIA_API_KEY=your_eia_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
MAPBOX_API_KEY=your_mapbox_api_key
