#!/usr/bin/env bash
# ./launch — the ONE reliable way to see the app.
#
# What it does, start to finish:
#   1. Refuses to run if there are unsaved (uncommitted) changes — those would
#      silently NOT appear on the site, which is exactly the "old version" trap.
#   2. Pushes main to GitHub (that triggers the Render deploy of both services).
#   3. Waits for BOTH Render deploys to finish building.
#   4. Verifies the live site is really running that exact commit
#      (backend /version + frontend /version.json must match your git HEAD).
#   5. Opens https://supply-chain-ui-bhwz.onrender.com in your browser.
#
# So when the browser opens, what you see is guaranteed to be the newest code.
# The top-right of the app's nav bar shows "build <hash>" — it should match the
# hash this script prints. Never use localhost to view the app.
set -euo pipefail
cd "$(dirname "$0")"

UI_URL="https://supply-chain-ui-bhwz.onrender.com"
API_URL="https://supply-chain-api-qy8x.onrender.com"
API_SRV="srv-d98ru31o3t8c73ed9dig"   # supply-chain-api
UI_SRV="srv-d98ru9ss728c73c85bqg"    # supply-chain-ui
DEPLOY_TIMEOUT_MIN=25

say()  { printf '\033[1;34m▸ %s\033[0m\n' "$*"; }
ok()   { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m! %s\033[0m\n' "$*"; }
fail() { printf '\033[1;31m✗ %s\033[0m\n' "$*"; exit 1; }

# ── 0. Sanity checks ─────────────────────────────────────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)
[[ "$BRANCH" == "main" ]] || fail "You're on branch '$BRANCH', but only 'main' deploys to the live site.
  Ask Claude to merge this branch into main, then launch again."

if [[ -n "$(git status --porcelain)" && "${1:-}" != "--anyway" ]]; then
  echo
  git status --short
  echo
  fail "There are unsaved (uncommitted) changes — they would NOT show up on the site.
  Ask Claude to 'commit and push everything, then launch', or run
  './launch --anyway' to view only what's already committed."
fi

# ── 1. Push (this is what triggers the deploy) ───────────────────────────────
git fetch -q origin main
if [[ -n "$(git log origin/main..HEAD --oneline 2>/dev/null)" ]]; then
  say "Pushing latest commits to GitHub (this starts the deploy)…"
  git push -q origin main
  PUSHED=1
else
  say "Everything is already pushed — checking what's live…"
  PUSHED=0
fi

HEAD_SHA=$(git rev-parse HEAD)
SHORT=${HEAD_SHA:0:7}
say "Target version: $SHORT — \"$(git log -1 --format=%s)\""

# ── 2. Render API key (for deploy-status polling) ────────────────────────────
if [[ -z "${RENDER_API_KEY:-}" && -f backend/.env ]]; then
  RENDER_API_KEY=$(grep -E '^RENDER_API_KEY=' backend/.env | tail -1 | cut -d= -f2- | tr -d '"' | tr -d "'" || true)
fi

# latest_deploy <service-id> → "STATUS COMMIT_SHA" of the newest deploy
latest_deploy() {
  curl -sf --max-time 20 "https://api.render.com/v1/services/$1/deploys?limit=1" \
    -H "Authorization: Bearer $RENDER_API_KEY" \
  | python3 -c 'import json,sys
d = json.load(sys.stdin)[0]["deploy"]
print(d["status"], d.get("commit", {}).get("id", "unknown"))' 2>/dev/null || echo "api_error unknown"
}

# live_commit_api / live_commit_ui → the commit the LIVE site is serving
live_commit_api() {
  curl -sf --max-time 90 "$API_URL/version" \
  | python3 -c 'import json,sys; print(json.load(sys.stdin).get("commit","unknown"))' 2>/dev/null || echo "unreachable"
}
live_commit_ui() {
  curl -sf --max-time 30 -H 'Cache-Control: no-cache' "$UI_URL/version.json?nocache=$(date +%s)" \
  | python3 -c 'import json,sys; print(json.load(sys.stdin).get("commit","unknown"))' 2>/dev/null || echo "unreachable"
}

# ── 3. Wait for both Render deploys to reach "live" at our commit ────────────
DEADLINE=$(( $(date +%s) + DEPLOY_TIMEOUT_MIN * 60 ))

if [[ -n "${RENDER_API_KEY:-}" ]]; then
  say "Waiting for Render to build & deploy both services (usually 5–10 min)…"
  for pair in "backend:$API_SRV" "frontend:$UI_SRV"; do
    NAME=${pair%%:*}; SRV=${pair##*:}
    while true; do
      read -r STATUS COMMIT <<< "$(latest_deploy "$SRV")"
      if [[ "$COMMIT" == "$HEAD_SHA" ]]; then
        case "$STATUS" in
          live) ok "$NAME deployed ($SHORT is live)"; break ;;
          build_failed|update_failed|canceled|deactivated|pre_deploy_failed)
            fail "$NAME deploy FAILED (status: $STATUS).
  Ask Claude to check the Render logs and fix the build." ;;
          *) printf '  … %s: %s\r' "$NAME" "$STATUS" ;;
        esac
      else
        # Newest deploy is still an older commit → GitHub Action hasn't fired yet
        printf '  … %s: waiting for new deploy to start\r' "$NAME"
      fi
      [[ $(date +%s) -lt $DEADLINE ]] || fail "$NAME deploy didn't finish within ${DEPLOY_TIMEOUT_MIN} min.
  Check https://dashboard.render.com or ask Claude to investigate."
      sleep 15
    done
  done
else
  warn "No RENDER_API_KEY found (backend/.env) — falling back to polling the live site directly."
  say "Waiting for the live site to serve commit $SHORT (usually 5–10 min)…"
  while true; do
    A=$(live_commit_api); U=$(live_commit_ui)
    [[ "$A" == "$HEAD_SHA" && "$U" == "$HEAD_SHA" ]] && break
    printf '  … api:%.7s ui:%.7s (want %s)\r' "$A" "$U" "$SHORT"
    [[ $(date +%s) -lt $DEADLINE ]] || fail "Live site still isn't on $SHORT after ${DEPLOY_TIMEOUT_MIN} min.
  Check https://dashboard.render.com or ask Claude to investigate."
    sleep 20
  done
fi

# ── 4. Final proof: the LIVE site itself reports our commit ──────────────────
say "Verifying the live site (also wakes the free-tier backend, ~1 min)…"
API_LIVE=$(live_commit_api)
UI_LIVE=$(live_commit_ui)

if [[ "$API_LIVE" == "$HEAD_SHA" && "$UI_LIVE" == "$HEAD_SHA" ]]; then
  ok "Verified: live site is running exactly $SHORT (backend + frontend)"
elif [[ "$API_LIVE" == "unreachable" || "$API_LIVE" == "unknown" ]]; then
  warn "Deploys are live but the backend /version check couldn't confirm (it may still be waking up)."
  warn "The nav bar's 'build' stamp in the app should read: $SHORT"
else
  warn "Version endpoints report api:${API_LIVE:0:7} ui:${UI_LIVE:0:7} (expected $SHORT)."
  warn "If the page looks stale, do a hard refresh (Cmd+Shift+R)."
fi

# ── 5. Open it ────────────────────────────────────────────────────────────────
echo
ok "READY → $UI_URL"
ok "Look for 'build $SHORT' in the top-right of the app's nav bar."
command -v open >/dev/null && open "$UI_URL"
